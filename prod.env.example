# 生产环境对外端口。
# 宿主机 Nginx 保持反代到 127.0.0.1:${PORT}，但这个端口现在对应项目自己的 Nginx 容器。
PORT=10011

# 数据库配置。
# 如果数据库运行在宿主机，请不要使用 localhost/127.0.0.1，容器内应改为 host.docker.internal。
SQL_DSN=postgres://new_api:new_api_password@host.docker.internal:5432/new_api?sslmode=disable
LOG_SQL_DSN=postgres://new_api:new_api_password@host.docker.internal:5432/new_api?sslmode=disable

# 运行模式
GIN_MODE=release

# 其他配置
SESSION_SECRET=change-this-to-a-random-secret
SQL_MAX_IDLE_CONNS=100
SQL_MAX_OPEN_CONNS=1000
SQL_MAX_LIFETIME=60

# 缓存。若 Redis 在宿主机，同样改为 host.docker.internal。
REDIS_CONN_STRING=
MEMORY_CACHE_ENABLED=true
SYNC_FREQUENCY=60
